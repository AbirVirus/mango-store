# MongoDB connection string (get from MongoDB Atlas)
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/mango-store?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/mango-store

# Resend API key for email notifications (get from https://resend.com)
# Leave blank to skip sending emails during local development
RESEND_API_KEY=

# Admin email to receive new order notifications
ADMIN_EMAIL=admin@example.com

# Public site URL (used in email links)
# Local: http://localhost:3000
# Production: https://your-domain.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
